{
	"name": "json-canvas-viewer",
	"version": "4.1.1",
	"description": "An extensible web-based viewer for JSON Canvas, easy to embed into websites.",
	"keywords": [
		"frontend",
		"html-canvas",
		"json-canvas",
		"obsidian-md",
		"typescript"
	],
	"homepage": "https://github.com/hesprs/json-canvas-viewer",
	"bugs": {
		"url": "https://github.com/hesprs/json-canvas-viewer/issues"
	},
	"license": "MIT",
	"author": {
		"name": "Hēsperus",
		"email": "hesprs@outlook.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hesprs/json-canvas-viewer.git"
	},
	"files": [
		"./dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"unpkg": "./dist/chimp.js",
	"jsdelivr": "./dist/chimp.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"dev": "vite",
		"lint": "oxlint --type-aware --fix && oxfmt",
		"build": "tsdown && MODE=chimp tsdown",
		"check": "tsc && oxfmt --check && oxlint --type-aware"
	},
	"dependencies": {
		"@ahmedsemih/color-fns": "^1.3.0",
		"@needle-di/core": "^1.1.2",
		"dompurify": "^3.4.1",
		"marked": "^18.0.2",
		"pointeract": "^1.2.0"
	},
	"devDependencies": {
		"@repo/shared": "workspace:*",
		"@tsdown/css": "^0.21.10",
		"sass": "^1.99.0",
		"vite-plugin-json-canvas": "workspace:*"
	},
	"packageManager": "pnpm@10.24.0"
}
