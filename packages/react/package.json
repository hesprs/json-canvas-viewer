{
	"name": "@json-canvas-viewer/react",
	"version": "1.0.2",
	"description": "An extensible web-based viewer for JSON Canvas in the form of a React component, easy to embed into websites.",
	"keywords": [
		"frontend",
		"html-canvas",
		"json-canvas",
		"obsidian-md",
		"react",
		"react-components",
		"typescript"
	],
	"homepage": "https://github.com/hesprs/json-canvas-viewer",
	"bugs": {
		"url": "https://github.com/hesprs/json-canvas-viewer/issues"
	},
	"license": "MIT",
	"author": {
		"name": "Hēsperus",
		"email": "hesprs@outlook.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hesprs/json-canvas-viewer.git"
	},
	"files": [
		"./dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"lint": "oxlint --type-aware --fix && oxfmt",
		"build": "tsdown",
		"check": "tsc && oxfmt --check && oxlint --type-aware",
		"dev": "vite"
	},
	"dependencies": {
		"json-canvas-viewer": "workspace:*"
	},
	"devDependencies": {
		"@repo/shared": "workspace:*",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"vite-plugin-json-canvas": "workspace:*"
	},
	"peerDependencies": {
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	}
}
